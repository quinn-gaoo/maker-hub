# 应用基础配置
APP_NAME=MakerHub API
APP_ENV=production
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/makerhub

# 认证与站点地址配置
INTERNAL_API_SIGNING_SECRET=
AUTH_SESSION_SECRET=
AUTH_BASE_URL=https://api.example.com
AUTH_FRONTEND_URL=https://example.com
PUBLIC_API_BASE_URL=https://api.example.com
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GOOGLE_REDIRECT_URI=https://api.example.com/api/v1/auth/google/callback
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GITHUB_REDIRECT_URI=https://api.example.com/api/v1/auth/github/callback

# 邮件发送与注册验证码配置
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=MakerHub
EMAIL_VERIFICATION_CODE_PREFIX=MKH
EMAIL_VERIFICATION_CODE_LENGTH=6
EMAIL_VERIFICATION_CODE_TTL_MINUTES=10
EMAIL_VERIFICATION_CODE_COOLDOWN_SECONDS=60

# 管理员邮箱，多个用英文逗号分隔
ADMIN_EMAILS=

# 腾讯云 COS 存储配置
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=
COS_PUBLIC_BASE_URL=
