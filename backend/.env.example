# 应用基础配置
APP_NAME=MakerHub API
APP_ENV=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/makerhub

# 邮箱验证码签名密钥，用于服务端生成和校验验证码哈希
EMAIL_VERIFICATION_SECRET=

# 第三方 OAuth 应用配置，由后端转交给 OAuth 代理换取用户信息
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# OAuth 代理配置，AUTH_PROXY_KEY 要和 portal 代理配置一致
AUTH_PROXY_URL=http://localhost:3000/api/proxy/oauth
AUTH_PROXY_KEY=

# 邮件发送与注册验证码配置
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=MakerHub
EMAIL_VERIFICATION_CODE_PREFIX=MKH
EMAIL_VERIFICATION_CODE_LENGTH=6
EMAIL_VERIFICATION_CODE_TTL_MINUTES=10
EMAIL_VERIFICATION_CODE_COOLDOWN_SECONDS=60

# 腾讯云 COS 存储配置
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=
COS_PUBLIC_BASE_URL=
